# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
CLIENT_URL=http://localhost:3000
CALLBACK_BASE_URL=http://localhost:4000
SESSION_SECRET=replace-with-a-long-random-string

# ── n8n ───────────────────────────────────────────────────────────────────────
# Your self-hosted n8n URL (inside Docker: use host.docker.internal if needed)
N8N_BASE_URL=http://localhost:5678
# Generate in n8n: Settings → API → Enable Public API → Create API Key
N8N_API_KEY=your-n8n-api-key

# ── User file uploads (optional) ───────────────────────────────────────────────
# Max size per file in megabytes (default 25). Files live under server/data/uploads.
UPLOAD_MAX_MB=25

# Optional: allow automation (e.g., n8n) to access uploads without a browser session.
# In n8n, send headers:
#   X-Lynx-Service-Key: <this value>
#   X-Lynx-User-Id: <target user id>   (or use ?userId=)
LYNX_UPLOADS_SERVICE_KEY=replace-with-a-long-random-string-at-least-16-chars

# ── Registration gate ─────────────────────────────────────────────────────────
# Share this with team members so they can create their accounts via POST /api/auth/register
REGISTER_SECRET=032005

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:4000/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft OAuth ───────────────────────────────────────────────────────────
# Register at: https://portal.azure.com → Azure Active Directory → App registrations
# Redirect URI: http://localhost:4000/api/oauth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ── Discord OAuth ─────────────────────────────────────────────────────────────
# Create at: https://discord.com/developers/applications → OAuth2
# Redirect URI: http://localhost:4000/api/oauth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── Notion OAuth ──────────────────────────────────────────────────────────────
# Create at: https://www.notion.so/my-integrations → New integration → OAuth
# Redirect URI: http://localhost:4000/api/oauth/notion/callback
# Note: Notion requires OAuth app review for public use — for internal/team use this is waived
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
