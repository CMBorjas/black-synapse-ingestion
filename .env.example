# Environment template for Black Synapse
# Copy this to .env and fill values before starting services

# OpenAI API key (used for embeddings if not using Azure)
OPENAI_API_KEY=

# Azure OpenAI (used by qdrant/ingest_azure.py)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-02-01

# Firecrawl API key (optional, for advanced web scraping)
FIRECRAWL_API_KEY=

# Qdrant URL (container default)
QDRANT_URL=http://localhost:6333

# Postgres connection URL (container default)
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/atlasai

# Worker host/port
APP_HOST=0.0.0.0
APP_PORT=8000

# Logging
LOG_LEVEL=INFO
