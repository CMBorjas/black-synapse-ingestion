# Environment configuration for Black Synapse Data Ingestion
# Copy this file to `.env` and fill in secrets (do NOT commit secret values to source control).

# OpenAI API Key (required)
OPENAI_API_KEY=

# Postgres connection string used by the worker
# Example (docker-compose in dev uses postgres:postgres@postgres:5432):
POSTGRES_URL=postgresql://postgres:password@postgres:5432/black_synapse

# Qdrant URL
QDRANT_URL=http://qdrant:6333

# Worker app binding (optional overrides)
APP_HOST=0.0.0.0
APP_PORT=8000

# Logging
LOG_LEVEL=INFO

# Perception service (perception/capture_frame.py)
# DEEPFACE_STREAM=false   # When false (default), no inference in capture loop — only via n8n
# STATE_FILE=perception_state.json   # n8n/VLM combined (faces + scene_caption)
# STREAM_FACE_FILE=stream_face_detection.json   # DeepFace stream face-only output
# PERSONALIZATION_PATH=personalization.json   # Per-person context for LLM (edit to add names/context)
# PROACTIVE_STATE_FILE=proactive_state.json   # Tracks last_interaction, last_greeting for proactive greeting
# QR_SCAN_ENABLED=true           # Decode campus location from QR in the camera feed → state.location
# QR_SCAN_INTERVAL=0.5           # Seconds between QR decode attempts on the live buffer
# QR_STREAM_OVERLAY=true         # On /stream MJPEG, draw QR boxes + label; also decodes each streamed frame

# Face registration (register-face endpoint)
# SIMILARITY_THRESHOLD=0.38         # Match threshold for identification
# MERGE_SIMILARITY_THRESHOLD=0.35   # Merge user_N into name when registering
# CLEAR_PRIMARY_RATIO=1.5           # Largest face must be this many times larger than second (multi-face)

# Notes:
# - After copying to .env, set OPENAI_API_KEY to your key.
# - For local Python dev (not Docker), you may want to set POSTGRES_URL to point at localhost.